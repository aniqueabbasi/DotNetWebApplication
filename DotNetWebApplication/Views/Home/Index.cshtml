@{
    ViewData["Title"] = "Home Page";
}
<h1 class="text-center mt-5">Welcome to Your ASP.NET Core MVC Application!</h1>
<!-- HERO SECTION -->
<div class="hero-section">

    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-md-8">

                <div class="card text-center p-5">

                    <div class="icon-circle mb-3">
                        <i class="bi bi-rocket-takeoff"></i>
                    </div>

                    <h1 class="fw-bold">Build Something Amazing</h1>

                    <p class="text-muted">
                        This is a modern ASP.NET Core MVC application with a beautiful,
                        customizable UI. You can change this to anything you want!
                    </p>

                    <div class="mt-4 d-flex justify-content-center gap-3">
                        <a class="btn btn-primary btn-lg px-4"
                               asp-controller="Category" asp-action="Index">
                            Get Started
                        </a>

                        <a class="btn btn-outline-secondary btn-lg px-4"
                               href="https://learn.microsoft.com/aspnet/core">
                            Learn More
                        </a>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>

<!-- FEATURES SECTION -->
<div class="features-section py-5 bg-light">
    <div class="container">
        <div class="row text-center g-4">

            <div class="col-md-4">
                <div class="feature-card p-4 h-100">
                    <i class="bi bi-lightning-charge"></i>
                    <h5 class="mt-3">Fast Performance</h5>
                    <p>Built with modern technologies for optimal performance and speed.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card p-4 h-100">
                    <i class="bi bi-shield-check"></i>
                    <h5 class="mt-3">Secure by Design</h5>
                    <p>Security best practices built-in from the ground up.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card p-4 h-100">
                    <i class="bi bi-code-slash"></i>
                    <h5 class="mt-3">Developer Friendly</h5>
                    <p>Clean, maintainable code that developers love to work with.</p>
                </div>
            </div>

        </div>
    </div>
</div>